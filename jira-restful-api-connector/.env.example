# jira-restful-api-connector — 環境變數模板
# 複製此檔案為 .env 並填入真實值
# 警告: .env 必須加入 .gitignore，禁止提交到版本庫

# Jira 實例 URL
JIRA_URL=http://your-jira-instance.com:8080

# 認證方式 A: Bearer Token
JIRA_API_TOKEN=your_api_token
