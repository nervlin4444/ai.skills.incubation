---
title: "Chrome Playwright Connector - Environment Example"
name: "chrome-playwright-connector"
description: "環境變數示例檔案。複製為 .env 並填入實際值。供人類和 Agent 參考。"
version: "1.0.0"
github_repository: "nervlin4444/ai.skills.incubation"
target_branch: "main"
updated_at: "2026-05-21T18:30:00+08:00"
auth_config:
  provider: "local"
  auth_method: "none"
  token_env_var: "N/A"
  env_file_path: "{baseDir}/.env"
file_mapping:
  local_path: "{baseDir}/.env.example"
  github_path: "chrome-playwright-connector/.env.example"
---
# ============================================
# Chrome Playwright Connector — Environment Example
# Copy this file to .env and fill in your values
# ============================================

# --------------------------------------------
# 1. Browser Default Settings
# --------------------------------------------
# Headless mode: true = background, false = visible window
CONNECTOR_HEADLESS=true

# Default timeout for all operations (milliseconds)
CONNECTOR_TIMEOUT=30000

# --------------------------------------------
# 2. Viewport Size
# --------------------------------------------
CONNECTOR_VIEWPORT_WIDTH=1400
CONNECTOR_VIEWPORT_HEIGHT=900

# --------------------------------------------
# 3. Directory Paths (optional)
# --------------------------------------------
# If left empty, uses skill-internal defaults under {baseDir}/
# Use absolute paths or paths relative to skill root

# CONNECTOR_PROFILES_DIR=./profiles
# CONNECTOR_DOWNLOADS_DIR=./downloads
# CONNECTOR_DIAGNOSE_DIR=./diagnose
# CONNECTOR_LOGS_DIR=./logs

# --------------------------------------------
# 4. Logging
# --------------------------------------------
# Levels: DEBUG, INFO, WARNING, ERROR
CONNECTOR_LOG_LEVEL=INFO
