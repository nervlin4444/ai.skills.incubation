{
  "_meta": {
    "title": "Kimi Tracker Unified Configuration",
    "name": "kimi-agent-tracker",
    "description": "Single source of truth. All tunable parameters centralized here. No .env required.",
    "version": "1.1.0",
    "github_repository": "nervlin4444/ai.skills.incubation",
    "target_branch": "main",
    "updated_at": "2026-05-25T02:15:00+08:00",
    "auth_config": {
      "provider": "local",
      "auth_method": "none",
      "token_env_var": "N/A",
      "env_file_path": "N/A"
    },
    "file_mapping": {
      "local_path": "{baseDir}/.config/kimi_tracker_config.json",
      "github_path": "kimi-agent-tracker/.config/kimi_tracker_config.json"
    }
  },
  "platform": {
    "base_url": "https://www.kimi.com"
  },
  "logging": {
    "level": "INFO",
    "log_dir": "{baseDir}/.logs",
    "keep_log_days": 7
  },
  "login": {
    "stay_open_default": 300,
    "validate_timeout_ms": 5000,
    "login_check_interval_sec": 3,
    "max_login_wait_sec": 600,
    "visible_default": true,
    "profile_name": "kimi_com",
    "force_reauth": false
  },
  "selectors": {
    "login_indicators": [
      ".chat-info-item",
      ".user-avatar",
      ".user-name"
    ],
    "conversation_items": ".chat-info-item",
    "user_avatar": ".user-avatar",
    "user_name": ".user-name",
    "new_chat_btn": ".new-chat-btn",
    "sidebar": ".sidebar"
  },
  "daemon": {
    "interval_sec": 60,
    "visible": false,
    "conversation_count": 10,
    "download_dir": "{baseDir}/Downloads",
    "duplicate_dir": "{baseDir}/skills_moved/.duplicate_downloads",
    "max_retry_per_conversation": 2
  },
  "download": {
    "direct_extensions": [".zip", ".py", ".csv", ".json", ".env"],
    "preview_extensions": [".md", ".txt"],
    "download_timeout_ms": 10000,
    "retry_delay_sec": 2,
    "max_retry": 1,
    "unique_filename": true,
    "deduplicate": true
  },
  "state": {
    "state_file": "{baseDir}/.config/downloads.json",
    "conversations_file": "{baseDir}/.config/conversations.json"
  },
  "diagnose": {
    "diagnose_dir": "{baseDir}/.logs/diagnose",
    "auto_diagnose_on_error": true,
    "keep_diagnose_count": 20
  }
}