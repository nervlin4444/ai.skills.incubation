  local_path: "{baseDir}/.env.example"
  github_path: "kimi-agent-tracker/.env.example"
---
# ============================================
# Kimi Agent Tracker — Environment Example
# Copy this file to .env and fill in your values
# ============================================

# --------------------------------------------
# 1. Kimi Platform
# --------------------------------------------
KIMI_BASE_URL=https://www.kimi.com

# --------------------------------------------
# 2. Daemon Cycle Settings
# --------------------------------------------
# Interval between download cycles (seconds)
# Default: 900 = 15 minutes
DAEMON_INTERVAL=900

# Number of conversations to extract per cycle
CONVERSATION_COUNT=10

# Run browser in visible mode during daemon cycles
# true = show window, false = headless
DAEMON_VISIBLE=false

# --------------------------------------------
# 3. Login Validation
# --------------------------------------------
# Retry count before aborting a daemon cycle
LOGIN_RETRY=1

# Force re-authentication on every daemon start
# Normally false — only set true if session expires frequently
LOGIN_FORCE_REAUTH=false

# --------------------------------------------
# 4. Download Settings
# --------------------------------------------
# Append _1, _2, _3... if filename already exists
DOWNLOAD_UNIQUE_FILENAME=true

# Enable SHA256 deduplication
DOWNLOAD_DEDUPLICATE=true

# --------------------------------------------
# 5. Directory Paths (optional)
# --------------------------------------------
# If left empty, uses skill-internal defaults under {baseDir}/
# Use absolute paths or paths relative to skill root

# TRACKER_DOWNLOADS_DIR=./downloads
# TRACKER_DUPLICATE_DIR=./.duplicate
# TRACKER_LOGS_DIR=./logs
# TRACKER_CONFIG_DIR=./.config

# --------------------------------------------
# 6. Logging
# --------------------------------------------
# Levels: DEBUG, INFO, WARNING, ERROR
TRACKER_LOG_LEVEL=INFO
