# ============================================
# github-skill-organizer 獨立配置
# ============================================
# 注意：GITHUB_TOKEN / GITHUB_OWNER 由依賴技能 github-restful-api-connector 提供
#       本技能自動從 DEPENDENCY_SKILL_PATH/.env 讀取

# 本地路徑（必填）
DOWNLOAD_FOLDER=~/Downloads/skills-inbox
USER_SKILLS_FOLDER=~/skills

# 依賴技能路徑（必填，用於讀取其 .env 中的 GITHUB_TOKEN / GITHUB_OWNER）
DEPENDENCY_SKILL=github-restful-api-connector
DEPENDENCY_SKILL_PATH=~/skills/github-restful-api-connector

# Daemon 設定（可選，有預設值）
SCAN_INTERVAL_SECONDS=60
PID_FILE_PATH=/tmp/github-skill-organizer.pid

# 審批設定（可選）
AUTO_APPROVE_PATCH=true
PATCH_MAX_FILES=3

# Web Fetcher（預設關閉，待主人確認後啟用）
ENABLE_WEB_FETCHER=false
WEB_FETCHER_INTERVAL_MINUTES=30
