{
  "version": "1.0.0",
  "skill_name": "github-skill-organizer",
  "workstation_defaults": {
    "linux": {
      "download_folder": "~/Downloads/skills-inbox",
      "skills_folder": "~/.local/share/openclaw/skills",
      "log_dir": "~/.local/share/openclaw/logs"
    },
    "macos": {
      "download_folder": "~/Downloads/skills-inbox",
      "skills_folder": "~/Library/Application Support/openclaw/skills",
      "log_dir": "~/Library/Logs/openclaw"
    },
    "windows": {
      "download_folder": "%USERPROFILE%\\Downloads\\skills-inbox",
      "skills_folder": "%APPDATA%\\openclaw\\skills",
      "log_dir": "%APPDATA%\\openclaw\\logs"
    }
  },
  "frontmatter_required_fields": [
    "title",
    "name",
    "description",
    "version",
    "github_repository",
    "target_branch",
    "auth_config",
    "file_mapping"
  ],
  "github_repository_format": "owner/repo",
  "version_bump_rules": {
    "patch": {
      "max_files": 3,
      "forbidden_patterns": [
        "SKILL.md",
        "config/",
        "requirements.txt"
      ],
      "description": "Typo fixes, path corrections, minor frontmatter updates"
    },
    "minor": {
      "description": "Feature additions, multi-file refactoring, new dependencies"
    },
    "major": {
      "description": "Breaking changes, skill merges, architecture shifts"
    }
  },
  "upload_gate": {
    "check_frontmatter": true,
    "check_semver": true,
    "check_hardcoded_paths": true,
    "hardcoded_path_patterns": [
      "/home/",
      "C:\\\\",
      "D:\\\\",
      "/Users/"
    ]
  },
  "commit_message_template": "[{bump_type}] {skill_name} v{new_version} by {agent_name}({model}) - {summary}"
}