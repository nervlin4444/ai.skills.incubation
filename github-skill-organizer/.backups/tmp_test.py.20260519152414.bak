#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
---
title: "Quick Sanity Test for github-skill-organizer Fixes"
name: "github-skill-organizer"
description: "Lightweight test runner to verify the 4 fixed scripts before agent uploads them to GitHub. No external dependencies required."
version: "v1.0.0"
github_repository: "nervlin4444/ai.skills.incubation"
target_branch: "main"
updated_at: "2026-05-19T21:02:00+08:00"

auth_config:
  provider: "github"
  auth_method: "token"
  token_env_var: "GITHUB_TOKEN"
  env_file_path: "{baseDir}/.env"

file_mapping:
  - local_path: "{baseDir}/scripts/tmp_test.py"
    github_path: "github-skill-organizer/scripts/tmp_test.py"
---
"""

"""
Tmp Test Runner — github-skill-organizer v1.0.2/v1.0.4 Fixes
============================================================
Tests the 4 critical fixes without requiring full skill environment.

Run:
    python tmp_test.py

Exit codes:
    0 = all tests passed, safe to upload
    1 = one or more tests failed, DO NOT upload
"""

import sys
import os
import re
import tempfile
import shutil
import json
from pathlib import Path
from datetime import datetime, timezone

# ============================================================
# Colour output helpers
# ============================================================
PASS = "[PASS]"
FAIL = "[FAIL]"
WARN = "[WARN]"

errors = []

def ok(msg):
    print(f"  {PASS} {msg}")

def fail(msg):
    print(f"  {FAIL} {msg}")
    errors.append(msg)

def warn(msg):
    print(f"  {WARN} {msg}")

# ============================================================
# Test 1: datetime.utcnow() eradication
# ============================================================
def test_no_deprecated_datetime():
    print("\n[Test 1] Verify datetime.utcnow() is NOT used in fixed scripts")
    scripts_dir = Path(__file__).parent
    targets = [
        scripts_dir / "sync_engine.py",
        scripts_dir / "local_scanner.py",
        scripts_dir / "skill_installer.py",
    ]
    found = 0
    for p in targets:
        if not p.exists():
            warn(f"{p.name} not found in same directory, skipped")
            continue
        content = p.read_text(encoding="utf-8")
        matches = re.findall(r"datetime\.utcnow\(\)", content)
        if matches:
            fail(f"{p.name} still contains {len(matches)} x datetime.utcnow()")
            found += len(matches)
        else:
            ok(f"{p.name} — no deprecated datetime.utcnow()")
    if found == 0:
        ok("All scanned scripts clean")
    return found == 0

# ============================================================
# Test 2: datetime.now(timezone.utc) presence
# ============================================================
def test_timezone_aware_datetime():
    print("\n[Test 2] Verify datetime.now(timezone.utc) IS used")
    scripts_dir = Path(__file__).parent
    targets = [
        scripts_dir / "sync_engine.py",
        scripts_dir / "local_scanner.py",
        scripts_dir / "skill_installer.py",
    ]
    found = 0
    for p in targets:
        if not p.exists():
            continue
        content = p.read_text(encoding="utf-8")
        if "datetime.now(timezone.utc)" in content:
            ok(f"{p.name} — uses timezone-aware datetime")
            found += 1
        else:
            fail(f"{p.name} — missing datetime.now(timezone.utc)")
    return found >= 3

# ============================================================
# Test 3: sync_engine Path fix (files[0].parent.parent)
# ============================================================
def test_sync_engine_path_fix():
    print("\n[Test 3] Verify sync_engine.py Path() wrapper fix")
    scripts_dir = Path(__file__).parent
    target = scripts_dir / "sync_engine.py"
    if not target.exists():
        warn("sync_engine.py not found, skipped")
        return True

    content = target.read_text(encoding="utf-8")

    # Must NOT have bare files[0].parent.parent
    bad = r"files\[0\]\.parent\.parent"
    if re.search(bad, content):
        fail("Still has raw files[0].parent.parent (str has no .parent)")
        return False

    # Must have Path(files[0]).parent.parent
    good = r"Path\(files\[0\]\)\.parent\.parent"
    if re.search(good, content):
        ok("Path(files[0]).parent.parent present")
        return True
    else:
        fail("Missing Path() wrapper around files[0]")
        return False

# ============================================================
# Test 4: commit_validator.py completeness
# ============================================================
def test_commit_validator_complete():
    print("\n[Test 4] Verify commit_validator.py is NOT truncated")
    scripts_dir = Path(__file__).parent
    target = scripts_dir / "commit_validator.py"
    if not target.exists():
        warn("commit_validator.py not found, skipped")
        return True

    content = target.read_text(encoding="utf-8")
    checks = [
        ("argparse import", "import argparse"),
        ("main() function", "def main():"),
        ("--message arg", '--message'),
        ("--batch arg", '--batch'),
        ("validate_batch function", "def validate_batch("),
        ("validate_full_message function", "def validate_full_message("),
        ("COMMIT_PATTERN regex", "COMMIT_PATTERN"),
        ("FULL_MESSAGE_PATTERN regex", "FULL_MESSAGE_PATTERN"),
        ("if __name__ == '__main__'", "if __name__ == '__main__':"),
    ]

    all_ok = True
    for name, needle in checks:
        if needle in content:
            ok(f"{name} — present")
        else:
            fail(f"{name} — MISSING (file may be truncated)")
            all_ok = False

    # Also check file size (truncated version was ~3KB, full is ~9KB)
    size = len(content)
    if size < 8000:
        fail(f"File suspiciously small ({size} chars), likely truncated")
        all_ok = False
    else:
        ok(f"File size {size} chars — looks complete")

    return all_ok

# ============================================================
# Test 5: commit_validator functional test
# ============================================================
def test_commit_validator_functional():
    print("\n[Test 5] Functional test: commit_validator.py regex logic")
    scripts_dir = Path(__file__).parent
    target = scripts_dir / "commit_validator.py"
    if not target.exists():
        warn("commit_validator.py not found, skipped")
        return True

    # Import the module dynamically
    import importlib.util
    spec = importlib.util.spec_from_file_location("commit_validator", target)
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)

    tests = [
        ("feat(scorer): add 429-aware rating", True),
        ("fix(core): replace utcnow with timezone.utc", True),
        ("docs(skill): update SKILL.md execution commands", True),
        ("update something", False),           # missing type
        ("feat: ", False),                    # empty subject
        ("fix(core): fixed the bug.", False), # past tense + period
        ("FIX(core): add something", False),  # uppercase type
        ("feat!: breaking change", True),     # breaking change marker
    ]

    all_ok = True
    for msg, expected in tests:
        valid, reason, parsed = mod.validate_full_message(msg)
        if valid == expected:
            ok(f'"{msg[:40]}..." -> {"VALID" if valid else "INVALID"}')
        else:
            fail(f'"{msg[:40]}..." -> expected {"VALID" if expected else "INVALID"}, got {"VALID" if valid else "INVALID"}')
            all_ok = False

    return all_ok

# ============================================================
# Test 6: skill_installer backup dir naming (.backups)
# ============================================================
def test_backup_dir_naming():
    print("\n[Test 6] Verify backup directory uses .backups (plural)")
    scripts_dir = Path(__file__).parent
    target = scripts_dir / "skill_installer.py"
    if not target.exists():
        warn("skill_installer.py not found, skipped")
        return True

    content = target.read_text(encoding="utf-8")
    if 'skill_dir / ".backups"' in content:
        ok("Backup dir is '.backups' (plural, matches sync_engine skip logic)")
        return True
    elif 'skill_dir / ".backup"' in content:
        fail("Backup dir is '.backup' (singular) — mismatched with sync_engine")
        return False
    else:
        fail("Cannot find backup dir definition")
        return False

# ============================================================
# Test 7: sync_engine compare_skill skips dot-files
# ============================================================
def test_sync_engine_skips_dotfiles():
    print("\n[Test 7] Verify sync_engine.py skips dot-files during comparison")
    scripts_dir = Path(__file__).parent
    target = scripts_dir / "sync_engine.py"
    if not target.exists():
        warn("sync_engine.py not found, skipped")
        return True

    content = target.read_text(encoding="utf-8")
    if 'local_file.name.startswith(".")' in content:
        ok("Skips files starting with '.' (covers .backups, .env, .git)")
        return True
    else:
        fail("Missing dot-file skip logic")
        return False

# ============================================================
# Main
# ============================================================
def main():
    print("=" * 60)
    print("github-skill-organizer Fix Verification Suite")
    print("=" * 60)
    print(f"Run at: {datetime.now(timezone.utc).isoformat()}")

    results = [
        test_no_deprecated_datetime(),
        test_timezone_aware_datetime(),
        test_sync_engine_path_fix(),
        test_commit_validator_complete(),
        test_commit_validator_functional(),
        test_backup_dir_naming(),
        test_sync_engine_skips_dotfiles(),
    ]

    print("\n" + "=" * 60)
    print("SUMMARY")
    print("=" * 60)
    passed = sum(results)
    total = len(results)
    print(f"Passed: {passed} / {total}")

    if errors:
        print(f"\nErrors ({len(errors)}):")
        for e in errors:
            print(f"  - {e}")

    if passed == total:
        print(f"\n{PASS} ALL TESTS PASSED — safe to upload to GitHub")
        sys.exit(0)
    else:
        print(f"\n{FAIL} {total - passed} TEST(S) FAILED — DO NOT upload, fix first")
        sys.exit(1)


if __name__ == "__main__":
    main()
