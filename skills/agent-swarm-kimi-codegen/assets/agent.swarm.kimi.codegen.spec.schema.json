{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agent.swarm.kimi.codegen.spec.schema",
  "version": "1.0",
  "description": "Structured Spec for Kimi Code Generation Subcontractor",
  "type": "object",
  "required": [
    "spec_version",
    "task_id",
    "language",
    "function_signature",
    "test_matrix",
    "execution_context"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "enum": [
        "1.0"
      ],
      "description": "Spec schema version"
    },
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z0-9-]+$",
      "description": "Unique task identifier, e.g. POS-BARCODE-007"
    },
    "domain": {
      "type": "string",
      "enum": [
        "retail",
        "devops",
        "finance",
        "inventory",
        "pos",
        "crm"
      ],
      "description": "Business domain for context caching"
    },
    "language": {
      "type": "string",
      "enum": [
        "python",
        "csharp",
        "powershell",
        "bash",
        "javascript",
        "sql"
      ],
      "description": "Target programming language"
    },
    "function_signature": {
      "type": "object",
      "required": [
        "name",
        "inputs",
        "outputs"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "type"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "constraints": {
                "type": "object",
                "properties": {
                  "length": {
                    "type": "integer"
                  },
                  "regex": {
                    "type": "string"
                  },
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  },
                  "enum_values": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "type"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "nullable": {
                "type": "boolean",
                "default": false
              }
            }
          }
        }
      }
    },
    "data_samples": {
      "type": "array",
      "maxItems": 2,
      "description": "v1.0 Token optimization: max 2 samples",
      "items": {
        "type": "object"
      }
    },
    "boundary_conditions": {
      "type": "array",
      "description": "List of boundary cases that MUST be handled",
      "items": {
        "type": "string"
      }
    },
    "test_matrix": {
      "type": "object",
      "required": [
        "normal_cases",
        "boundary_cases",
        "error_cases"
      ],
      "properties": {
        "normal_cases": {
          "type": "integer",
          "minimum": 1
        },
        "boundary_cases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error_cases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "pitfalls": {
      "type": "array",
      "description": "Historical lessons learned, injected into system prompt",
      "maxItems": 10,
      "items": {
        "type": "string",
        "maxLength": 100,
        "description": "Each pitfall <= 100 chars for Token efficiency"
      }
    },
    "execution_context": {
      "type": "object",
      "required": [
        "runtime",
        "sandbox_image"
      ],
      "properties": {
        "runtime": {
          "type": "string"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sandbox_image": {
          "type": "string"
        },
        "timeout_seconds": {
          "type": "integer",
          "default": 30
        }
      }
    },
    "existing_code_context": {
      "type": "string",
      "maxLength": 2000,
      "description": "v1.0: Only interface signatures + key constants, not full implementation"
    },
    "_v1_reserved": {
      "type": "object",
      "description": "v1.0 shielded features - reserved placeholders",
      "properties": {
        "generate_docs": {
          "type": "boolean",
          "default": false
        },
        "dependency_graph": {
          "type": "object",
          "properties": {
            "depth": {
              "type": "integer",
              "default": 0
            },
            "output": {
              "type": "null"
            }
          }
        },
        "history_context": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "summary"
              ],
              "default": "summary"
            },
            "full_payload": {
              "type": "null"
            }
          }
        },
        "multi_language": {
          "type": "boolean",
          "default": false
        },
        "test": {
          "type": "object",
          "properties": {
            "scope": {
              "type": "string",
              "enum": [
                "unit_only"
              ],
              "default": "unit_only"
            },
            "integration": {
              "type": "null"
            }
          }
        },
        "benchmark": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "metrics": {
              "type": "null"
            }
          }
        },
        "refactor": {
          "type": "object",
          "properties": {
            "suggestions": {
              "type": "boolean",
              "default": false
            },
            "patches": {
              "type": "null"
            }
          }
        }
      }
    }
  }
}